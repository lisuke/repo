# Maintainer: Sylvain POULAIN <sylvain dot poulain at giscan dot com>

pkgname=lerc
pkgver=4.2.0
pkgrel=1
pkgdesc='Limited Error Raster Compression library'
arch=(aarch64 x86_64)
url='https://github.com/Esri/lerc'
license=('Apache-2.0')
makedepends=('cmake')
source=("https://github.com/Esri/lerc/archive/refs/tags/v$pkgver.tar.gz")
sha512sums=('6ed82108d0ba4a6141cfb9ac7174a206488235e40e0eb2d34fa959716f6da3c6ec32562ceb5c9e77d02e1be5c73f24c81a3835f11dd57e4f87ca4003adafe47a')

build() {
  cd ${pkgname}-${pkgver}

  [[ -d build ]] || mkdir build

  cd build

  cmake -G "Unix Makefiles" .. \
        -DCMAKE_BUILD_TYPE="Release" \
        -DCMAKE_INSTALL_PREFIX=/usr/
  make
}

package() {
  cd ${pkgname}-${pkgver}/build

  make DESTDIR="${pkgdir}" install
}
