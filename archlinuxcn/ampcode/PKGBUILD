# Maintainer: Yuzu <aur at vitayuzu dot day>

pkgname=ampcode
pkgver=0.0.1784391370_g49c6a1
pkgrel=1
pkgdesc="The frontier coding agent."
arch=('x86_64')
url="https://ampcode.com"
license=('LicenseRef-Amp-Commercial-License')
depends=('gcc-libs' 'glibc')
provides=('amp')
conflicts=('amp')
options=("!strip")
_upstream_ver=${pkgver/_/-}
_archive="cli-linux-x64-${_upstream_ver}.tgz"
source=("${_archive}::https://registry.npmjs.org/@ampcode/cli-linux-x64/-/${_archive}")
sha512sums=('4ea2ceb963094584ea0ad0d35485153746dd4dbedff61519e7b3f209d9ddba4e8ddf06d6c3e4ed82dfdecea7f794807d86d841a780c03fff49653db41e4afadc')

package() {
    install -Dm755 "${srcdir}/package/amp" \
        "${pkgdir}/usr/bin/amp"
 
    install -Dm644 "${srcdir}/package/LICENSE.md" \
        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
 
    install -Dm644 "${srcdir}/package/README.md" \
        "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
