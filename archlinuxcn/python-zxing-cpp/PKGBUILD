# Maintainer: Gavin Luo <lunt.luo@gmail.com>

pkgname=python-zxing-cpp
pkgver=3.1.0
pkgrel=1
pkgdesc='Python bindings for zxing-cpp.'
url='https://github.com/zxing-cpp/zxing-cpp'
arch=('x86_64')
license=('Apache-2.0')
_name=${pkgname#python-}-${pkgver}
source=("${_name}.tar.gz::${url}/releases/download/v${pkgver}/${_name}.tar.gz")
b2sums=('14234dd58144e7a9aa0706d2d2d4b5c55e1dd464703bc422275ff1ab5ff7eb351bc9a0cdd59219ffe9a9d534c51c78e287975b17040e932cb8f17c9af07ca968')
depends=('python')
makedepends=(
    'python-build'
    'python-installer'
    'python-wheel'
    'python-scikit-build-core'
    'nanobind'
    'cmake>=3.18'
)

build() {
    cd "${srcdir}/${_name}/wrappers/python"
    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/${_name}/wrappers/python"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
