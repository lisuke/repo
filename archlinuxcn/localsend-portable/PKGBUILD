# Maintainer: Kimiblock Moe

pkgname=localsend-portable
pkgver=1.17.0
pkgrel=1
provides=(localsend)
conflicts=(localsend)
pkgdesc="AirDrop alternative. Sandboxed by portable."
arch=(x86_64)
url='https://localsend.org'
license=('Apache-2.0')
depends=(portable)
makedepends=(localsend)
source=(
	config.toml
	desktop.file
)
b2sums=('88c6cfd2ac178196515c79bfb37ecde8a60ba1b44631af0ba077d9d673d1e7193e5d3eb0f48b54ec1c9d7c0ed203708f7090019c71029c0b63ec8d7259698655'
        '1ee8212c4ebaffe9b5803c7367e271879918665545a702a5dfe7c9d6f7f8a8b9be71998f40af059f663030d117682be50acfa02a42258c4fc78ace9e777452e0')

package() {
	export pkgdir
	export pkgname
	export srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy localsend \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"

	ln -srf "${pkgdir}/usr/bin/localsend-portable" "${pkgdir}/usr/bin/localsend"
}
