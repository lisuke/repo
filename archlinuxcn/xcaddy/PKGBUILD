# Maintainer: OpenSorcerer <alex cat fossfed dog eu>
pkgname=xcaddy
pkgver=0.4.6
pkgrel=1
pkgdesc="Build Caddy with plugins"
arch=('i686' 'x86_64' 'armv7h' 'aarch64')
url="https://github.com/caddyserver/xcaddy"
license=('Apache-2.0')
depends=('go' 'glibc')
makedepends=('git')
source=("git+$url.git#tag=v$pkgver")
sha512sums=('d87797a47c31b3484d141e6d02eff6d9e39c3c887bb6322f6dddb7c7c8634bf22255e14b448278a0906056f688a219b6fcdd47a5f025e7fd8a9a52ec348b810e')

build() {
    cd "$pkgname"
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -trimpath -modcacherw"
    go build -o xcaddy "cmd/$pkgname/main.go"
}

package() {
    cd "$pkgname"
    install -Dm755 "./xcaddy" "$pkgdir/usr/bin/xcaddy"
}
