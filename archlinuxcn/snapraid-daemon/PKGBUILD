# Maintainer: Hao Long <imlonghao@archlinuxcn.org>
# Contributor: Andrea Mazzoleni <amadvance@gmail.com>

pkgname=snapraid-daemon
pkgver=1.13
pkgrel=1
pkgdesc="A background service with a built-in Web UI that automates SnapRAID operations"
arch=('x86_64')
url="https://www.snapraid.it/"
license=('GPL-3.0-or-later')
depends=('glibc' 'zlib' 'zstd' 'snapraid>=14.1')
makedepends=('zip')
backup=('etc/snapraidd.conf')
source=("https://github.com/amadvance/$pkgname/releases/download/v$pkgver/$pkgname-$pkgver.tar.gz")
b2sums=('3b476e3dc61d368c6220648deb75cdde1d85434884d578b8d5d9281e75aac562b2fd270fbaa3f318ff01f501a4b55869073bbdf18b83ca896d545d0db67d9e29')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir/" install
  install -Dm644 snapraidd.yaml "$pkgdir/usr/share/doc/$pkgname/snapraidd.yaml"
  install -Dm644 AUTHORS "$pkgdir/usr/share/doc/$pkgname/AUTHORS"
  install -Dm644 HISTORY "$pkgdir/usr/share/doc/$pkgname/HISTORY"
  install -Dm644 README "$pkgdir/usr/share/doc/$pkgname/README"
  install -Dm644 commander.zip "$pkgdir/usr/share/snapraidd/commander.zip"
  install -Dm644 snapraidd.conf.example "$pkgdir/etc/snapraidd.conf"
}
