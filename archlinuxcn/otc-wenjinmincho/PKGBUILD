# Maintainer: Coelacanthus <uwu@coelacanthus.name>

pkgbase=otc-wenjinmincho
pkgname=(
    otc-wenjinmincho
    otf-wenjinmincho
    ttc-wenjinmincho
    ttf-wenjinmincho
)
pkgver=2.012
pkgrel=1
pkgdesc='A large Han-ideograph character set Songti(Mincho) font suite.'
url='https://github.com/takushun-wu/WenJinMincho'
arch=('any')
license=('OFL-1.1')
makedepends=(git)
source=(
    $pkgbase::git+$url.git#tag=v$pkgver
    )
b2sums=('ae8311925122614ce745a09b0e338a9f020c5d703cb449ffc15657512585e57b93d94e3b51efaa342c767d1ae82fbb3f648706eca4bed6daac233d5ac0c0af97')

build() {
    cd "$pkgbase"
}

package_ttc-wenjinmincho() {
    cd "$pkgbase"
    install -Dm644 -t "$pkgdir/usr/share/fonts/TTF/$pkgname" ttc/WenJinMincho-TTF.ttc
    install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE.md
}
package_otc-wenjinmincho() {
    cd "$pkgbase"
    install -Dm644 -t "$pkgdir/usr/share/fonts/OTF/$pkgname" ttc/WenJinMincho-OTF.ttc
    install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE.md
}
package_ttf-wenjinmincho() {
    cd "$pkgbase"
    install -Dm644 -t "$pkgdir/usr/share/fonts/TTF/$pkgname" ttf/WenJinMinchoP[0-9]-*.ttf
    install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE.md
}
package_otf-wenjinmincho() {
    cd "$pkgbase"
    install -Dm644 -t "$pkgdir/usr/share/fonts/OTF/$pkgname" otf/WenJinMinchoP[0-9]-*.otf
    install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE.md
}
