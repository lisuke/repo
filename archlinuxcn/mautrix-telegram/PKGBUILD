# Maintainer: BrainDamage
pkgname=mautrix-telegram
pkgver=0.2607.0
pkgrel=1
pkgdesc="Matrix-Telegram hybrid puppeting/relaybot bridge"
url="https://github.com/tulir/mautrix-telegram"
depends=(libolm glibc libstdc++)
makedepends=(go 'git')
optdepends=()
license=('AGPL-3.0-only')
arch=('x86_64' 'aarch64')
source=("${pkgname}::git+${url}#tag=v${pkgver}" "${pkgname}.service")
sha256sums=('64a8d6d38237e9b6ed1b416ae45bea08d46ed134bf811e111cc71f25e32b0f06'
            '6e006c52add0c373cb9e409a61eb72dec2ed7f5a1e3cc35eadfec3bdf1fc3d9d')
backup=("etc/${pkgname}/config.yaml" "etc/${pkgname}/registration.yaml")


prepare() {
	cd "${srcdir}/${pkgname}"
	#bash build.sh
}

build() {
	cd "${srcdir}/${pkgname}"
	bash build.sh
}

package() {
	cd "${srcdir}/${pkgname}"
	install -vDm755 \
		mautrix-telegram \
		-t "${pkgdir}/usr/bin/"

	install -vDm644 \
		"${srcdir}/${pkgname}.service" \
		-t "${pkgdir}/usr/lib/systemd/system/"
	install -d "${pkgdir}/etc/${pkgname}/"
	curl \
		https://docs.mau.fi/configs/mautrix-telegram/latest.yaml \
		-Lo \
		"${pkgdir}/etc/${pkgname}/config.yaml"
	chmod 600 "${pkgdir}/etc/${pkgname}/config.yaml"
}
